{
  "name": "@efanworks/babel-exp",
  "version": "1.0.1-alpha.15",
  "description": "",
  "type": "module",
  "exports": {
    ".": {
      "import": "./lib/index.js",
      "require": "./lib/index.js"
    },
    "./components": {
      "import": "./lib/components/index.js",
      "types": "./lib/types/components/index.d.ts"
    }
  },
  "browserslist": [
    "> 0.5%, last 2 versions"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "type-check": "tsc --noEmit",
    "build": "rm -rf lib && tsc && babel src --out-dir lib --extensions \".ts,.tsx,.js,.jsx\"",
    "prepare": "husky",
    "prepublishOnly": "npm run build",
    "service-start": "node --import tsx src/service.ts"
  },
  "files": [
    "lib"
  ],
  "lint-staged": {
    "*.{js,ts,mjs,mts}": [
      "prettier --write --ignore-unknown",
      "eslint --fix"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-arrow-functions": "^7.27.1",
    "@babel/preset-env": "^7.29.5",
    "@babel/preset-react": "^7.29.7",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/react": "^19.2.15",
    "@types/uuid": "^10.0.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4"
  },
  "dependencies": {
    "@types/cors": "^2.8.19",
    "core-js": "^3.49.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "react-error-boundary": "^6.1.2",
    "uuid": "^14.0.0",
    "zustand": "^5.0.14"
  },
  "peerDependencies": {
    "@reduxjs/toolkit": "2.12.0",
    "react": "19.2.7",
    "react-redux": "9.3.0"
  }
}
